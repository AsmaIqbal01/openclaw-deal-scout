# Required — path to the OAuth client credentials JSON downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=

# Required — Gemini API key from Google AI Studio (free tier)
GEMINI_API_KEY=

# Optional — path to the JSON state store file (default shown)
STATE_STORE_PATH=./data/processed_ids.json

# Optional — maximum emails fetched per poll cycle (default shown)
MAX_MESSAGES_PER_POLL=50

# ── 002-hubspot-crm-logger ────────────────────────────────────────────────────

# Required — HubSpot Private App token (Settings → Integrations → Private Apps)
HUBSPOT_PRIVATE_APP_TOKEN=

# ── 003-discord-notification ─────────────────────────────────────────────────

# Required — selects the notification adapter; valid values: discord | noop
NOTIFIER=discord

# Required when NOTIFIER=discord — the full webhook URL from Discord channel settings
# (never commit this value; add .env to .gitignore)
DISCORD_WEBHOOK_URL=
